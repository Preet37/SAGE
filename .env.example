# ─────────────────────────────────────────────────────────────
#  TutorAgent – Docker Compose Environment Variables
#  Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# LLM API key (required — works with any OpenAI-compatible provider)
# OpenAI: get a key at https://platform.openai.com/api-keys
# NVIDIA: get a key at https://build.nvidia.com/
LLM_API_KEY=your-api-key-here

# JWT signing secret (change for any shared deployment)
JWT_SECRET=change-me-in-production-use-long-random-string

# Search API key (optional — enables the tutor's web search tool)
# Get a Perplexity key at https://docs.perplexity.ai/
# SEARCH_API_KEY=your-perplexity-api-key-here

# Frontend URL for CORS (comma-separated for multiple origins)
# Default: http://localhost:3000
# Set to * for permissive internal testing, or the real URL for remote deploys
# FRONTEND_URL=http://localhost:3000

# Backend API URL baked into the frontend JS bundle at build time
# Default: http://localhost:8000
# Change to http://<host-ip>:8000 when deploying on a remote machine
# NEXT_PUBLIC_API_URL=http://localhost:8000

# ─────────────────────────────────────────────────────────────
#  Hackathon track integrations (all optional — features behind flags
#  in backend/settings.yaml)
# ─────────────────────────────────────────────────────────────

# Cloudinary (track 4) — needed for /sketch and lesson media uploads.
# Sign up free at https://cloudinary.com.
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Fetch.ai (track 1) — needed only when running the SAGE uAgent.
# FETCHAI_AGENT_SEED is a 24+ char string; pick something stable so the
# agent's address persists across restarts. AGENTVERSE_API_KEY is needed
# only for programmatic registration (manual registration via the UI works
# without it).
# FETCHAI_AGENT_SEED=please-set-a-long-random-stable-seed-here
# AGENTVERSE_API_KEY=your-agentverse-api-key

# Arista resource router (track 5) — YouTube is optional; arXiv and GitHub
# work without keys.
# YOUTUBE_API_KEY=your-youtube-data-api-key
