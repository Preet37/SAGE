DATABASE_URL=sqlite:///./sage.db
JWT_SECRET=replace-with-a-long-random-string
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=1440

# Optional LLM provider keys. When empty, SAGE uses an offline stub.
ANTHROPIC_API_KEY=
ASI1_API_KEY=

# Fetch.ai uAgents (optional, only if you run the agentverse runner)
AGENT_SEED=
AGENT_PORT=8001
