# Secrets only — all other config lives in settings.yaml

# LLM API key (required)
# Works with any OpenAI-compatible provider (OpenAI, NVIDIA, Azure, Together, etc.)
LLM_API_KEY=your-api-key-here

# JWT signing secret (change for production — use a long random string)
JWT_SECRET=change-me-in-production-use-long-random-string

# Search API key (optional — enables the tutor's web search tool)
# Default provider is Perplexity; change search.base_url in settings.yaml for others
# SEARCH_API_KEY=your-perplexity-api-key-here

# Frontend URL (comma-separated for CORS — include Course Creator port if used)
# FRONTEND_URL=http://localhost:3000,http://localhost:3001
