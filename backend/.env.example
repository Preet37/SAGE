# ── LLM Provider (required) ──────────────────────────────
LLM_API_KEY=sk-ant-your-key-here
LLM_PROVIDER=anthropic            # anthropic | openai | nvidia

# ── Fetch.ai (required for agent tracks) ─────────────────
AGENTVERSE_API_KEY=your-agentverse-key
ASI1_API_KEY=your-asi1-mini-key   # same as agentverse key usually

# ── Auth ─────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256

# ── Database ─────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./sage.db

# ── Optional: Voice (ElevenLabs) ─────────────────────────
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# ── Optional: Search (Perplexity) ────────────────────────
SEARCH_API_KEY=pplx-your-key

# ── Server ───────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_PORT=8000
CONTENT_DIR=./content
